# ===========================================
# Dynsense Environment Configuration
# Ref: FR-504 — .env.example with all required variables
# Copy to .env and fill in values
# ===========================================

# ---- Database (PostgreSQL 16 + pgvector) ----
DATABASE_URL=postgresql://dynsense:dynsense_dev@localhost:5432/dynsense

# ---- Redis 7 ----
REDIS_URL=redis://localhost:6379

# ---- API Server ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- JWT Auth (RS256) — Ref: design-doc §8.1 ----
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRY=1h
JWT_REFRESH_TOKEN_EXPIRY=30d

# ---- AWS Bedrock (Claude AI) — SOC 2 compliant, data stays in AWS ----
AWS_REGION=us-east-1
# AWS credentials are loaded from IAM role (ECS), environment, or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
